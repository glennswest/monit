# monit configuration — copy to /etc/monit/monit.conf and edit.
# Format: key = value   (# starts a comment)
# Environment variables (MONIT_AI_HOST, ...) override these at runtime.

# SSH target for the remote GPU host. Must allow key-based, non-interactive
# root login from the host running monit (BatchMode is used; no passwords).
ai_host = root@gpu-host.local

# Panel label for the local host. Defaults to the system hostname if unset.
#pve_label = hypervisor

# Panel label for the remote host. Defaults to the host part of ai_host.
#ai_label = gpu-host

# Data refresh interval, seconds.
refresh = 2

# Seconds per page before rotating to the next.
page_secs = 8

# Rows of top consumers shown per host.
top = 8

# Temperature unit: C or F.
temp_unit = C

# Overscan inset in pixels, applied on every edge of the Overview. Raise this if
# the display crops its edges (common on HDMI panels/TVs) and content falls off
# the visible area. 0 = draw edge-to-edge. Default: 0.
#overscan = 48

# Explicit drawable viewport for the Overview, in framebuffer pixels. Use this
# when the panel shows only PART of the framebuffer (e.g. it scales the left
# region to fill the screen) — point the overview at exactly the visible
# rectangle. A zero width or height falls back to the full framebuffer (minus
# overscan). Example: a panel showing only the left ~1040px, full height:
#view_x = 0
#view_y = 0
#view_w = 1040
#view_h = 0

# REST API for app-pushed pages. Bind address for the HTTP listener; set to
# "off" (or leave empty) to disable the API entirely. Default 0.0.0.0:9090.
api_bind = 0.0.0.0:9090

# Optional bearer token. If set, every /api/v1/* request must send
#   Authorization: Bearer <token>
# (the /healthz endpoint never requires auth). Leave unset for an open,
# LAN-trusted API.
#api_token = change-me

# Enable the power-control endpoint (/api/v1/power) that caps/restores the CPU
# package power via RAPL — useful during UPS overload. monit runs as root so it
# can apply the cap directly. Strongly pair this with api_token. Default: true.
api_control = true
